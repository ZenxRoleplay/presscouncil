    {
        "image": "../uploads/slider/1750412984_Slide3 (1).jpeg",
        "caption": "\u092e\u093e\u0939\u093f\u0924\u0940 \u0935 \u091c\u0928\u0938\u0902\u092a\u0930\u094d\u0915 \u092e\u0939\u093e\u0938\u0902\u091a\u093e\u0932\u0928\u093e\u0932\u092f\u093e\u0926\u094d\u0935\u093e\u0930\u0947 \u092e\u093e\u0928\u094d\u092f\u0924\u093e\u092a\u094d\u0930\u093e\u092a\u094d\u0924 \u092a\u0924\u094d\u0930\u0915\u093e\u0930\u093e\u0902\u0938\u093e\u0920\u0940\u091a\u094d\u092f\u093e \u2018\u0936\u0902\u0915\u0930\u0930\u093e\u0935 \u091a\u0935\u094d\u0939\u093e\u0923 \u0938\u0941\u0935\u0930\u094d\u0923 \u092e\u0939\u094b\u0924\u094d\u0938\u0935\u0940 \u092a\u0924\u094d\u0930\u0915\u093e\u0930 \u0915\u0932\u094d\u092f\u093e\u0923 \u0928\u093f\u0927\u0940\u2019 \u0924\u0938\u0947\u091a \u2018\u0906\u091a\u093e\u0930\u094d\u092f \u092c\u093e\u0933\u0936\u093e\u0938\u094d\u0924\u094d\u0930\u0940 \u091c\u093e\u0902\u092d\u0947\u0915\u0930 \u0938\u0928\u094d\u092e\u093e\u0928 \u092f\u094b\u091c\u0928\u093e\u2019 \u092f\u093e \u092f\u094b\u091c\u0928\u093e\u0902\u092e\u0927\u094d\u092f\u0947 \u0938\u0941\u0927\u093e\u0930\u0923\u093e \u0915\u0930\u0923\u094d\u092f\u093e\u091a\u094d\u092f\u093e \u0926\u0943\u0937\u094d\u091f\u0940\u0928\u0947 \u092e\u0939\u093e\u0930\u093e\u0937\u094d\u091f\u094d\u0930 \u0936\u093e\u0938\u0928\u093e\u092e\u093e\u0930\u094d\u092b\u0924 \u0926\u093f\u0928\u093e\u0902\u0915 \u0967\u0969 \u091c\u0942\u0928 \u0968\u0966\u0968\u096b \u0930\u094b\u091c\u0940 \u092e\u0902\u0924\u094d\u0930\u093e\u0932\u092f\u093e\u0924 \u0906\u092f\u094b\u091c\u093f\u0924 \u092c\u0948\u0920\u0915\u0940\u0924, \u092e\u093e\u0939\u093f\u0924\u0940 \u0935 \u091c\u0928\u0938\u0902\u092a\u0930\u094d\u0915 \u092e\u0939\u093e\u0938\u0902\u091a\u093e\u0932\u0928\u093e\u0932\u092f\u093e\u091a\u0947 \u0938\u0902\u091a\u093e\u0932\u0915 (\u0935\u0943\u0924\u094d\u0924 \u0935 \u091c\u0928\u0938\u0902\u092a\u0930\u094d\u0915) \u092e\u093e. \u0921\u0949. \u0917\u0923\u0947\u0936 \u092e\u0941\u0933\u0947 \u092f\u093e\u0902\u0928\u093e \u0928\u093f\u0935\u0947\u0926\u0928 \u0938\u093e\u0926\u0930 \u0915\u0930\u0924\u093e\u0928\u093e, \u092a\u094d\u0930\u0947\u0938 \u0915\u0949\u0928\u094d\u0938\u093f\u0932 \u0911\u092b \u092e\u0939\u093e\u0930\u093e\u0937\u094d\u091f\u094d\u0930\u093e\u091a\u0947 \u091a\u0947\u0905\u0930\u092e\u0928 \u0936\u094d\u0930\u0940. \u092e\u0939\u0947\u0936 \u091c\u094b\u0936\u0940, \u091c\u0928\u0930\u0932 \u0938\u0947\u0915\u094d\u0930\u0947\u091f\u0930\u0940 \u0936\u094d\u0930\u0940. \u0908\u0932\u093f\u092f\u093e\u0938 \u0916\u093e\u0928, \u0936\u094d\u0930\u0940. \u092d\u0930\u0924 \u092e\u093e\u0928\u0915\u0930 \u0924\u0938\u0947\u091a \u0935\u093f\u0935\u093f\u0927 \u092a\u0924\u094d\u0930\u0915\u093e\u0930 \u0938\u0902\u0918\u091f\u0928\u093e\u0902\u091a\u0947 \u092a\u094d\u0930\u0924\u093f\u0928\u093f\u0927\u0940 \u0909\u092a\u0938\u094d\u0925\u093f\u0924 \u0939\u094b\u0924\u0947.",
        "fontSize": 16
    },
